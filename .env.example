# Neuravolt Cloud Environment Variables Template

# Node Environment
NODE_ENV=development
PORT=3000

# Databases
DATABASE_URL="postgresql://neuravolt:neuravolt_dev_pwd@localhost:5432/neuravolt?schema=public"
REDIS_URL="redis://localhost:6379"

# Authentication
JWT_SECRET_FILE="./secrets/jwt_secret"
NEXTAUTH_SECRET="neuravolt_dev_jwt_secret_key_extremely_long_and_secure_value_12345!"
NEXTAUTH_URL="http://localhost:3001" # User Portal URL (app)
NEXTAUTH_ADMIN_URL="http://localhost:3002" # Admin Portal URL

# Web APIs & Gateways
NEXT_PUBLIC_API_URL="http://localhost:3000"
RESEND_API_KEY="re_dev_key_placeholder_value"
STRIPE_SECRET_KEY="sk_test_placeholder"
STRIPE_WEBHOOK_SECRET_FILE="./secrets/stripe_webhook_secret"
